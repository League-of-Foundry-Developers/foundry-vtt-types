{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "@league-of-foundry-developers/foundry-vtt-types",
  "version": "14.365.0",
  "description": "TypeScript type definitions for Foundry VTT",
  "keywords": [
    "foundry",
    "foundry-vtt",
    "types",
    "typescript"
  ],
  "homepage": "https://github.com/League-of-Foundry-Developers/foundry-vtt-types",
  "bugs": {
    "url": "https://github.com/League-of-Foundry-Developers/foundry-vtt-types/issues"
  },
  "license": "MIT",
  "contributors": [
    {
      "name": "LukeAbby"
    },
    {
      "name": "Kai Moschcau"
    },
    {
      "name": "Johannes Loher"
    },
    {
      "name": "Oskar Pfeifer-Bley"
    },
    {
      "name": "FloRad"
    },
    {
      "name": "NickEastNL"
    },
    {
      "name": "BoltsJ"
    },
    {
      "name": "JPMeehan"
    }
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/League-of-Foundry-Developers/foundry-vtt-types.git"
  },
  "files": [
    "src",
    "tsconfig.base.json",
    "tsconfig.json"
  ],
  "type": "module",
  "types": "./src/index.d.mts",
  "imports": {
    "#client/*": {
      "import": "./src/foundry/client/*"
    },
    "#common/*": {
      "import": "./src/foundry/common/*"
    },
    "#utils": {
      "import": "./src/utils/index.d.mts"
    },
    "#configuration": {
      "import": "./src/configuration/index.d.mts"
    },
    "#tests/*": {
      "import": "./tests/foundry/*"
    },
    "#testUtils": {
      "import": "./tests/utils.ts"
    }
  },
  "exports": {
    ".": {
      "types": "./src/index.d.mts"
    },
    "./lenient": {
      "types": "./src/index-lenient.d.mts"
    },
    "./utils": {
      "types": "./src/utils/index.d.mts"
    },
    "./configuration": {
      "types": "./src/configuration/index.d.mts"
    },
    "./workers": {
      "types": "./src/foundry/public/scripts/workers/index.d.mts"
    },
    "./workers/image-compressor": {
      "types": "./src/foundry/public/scripts/workers/image-compressor.d.mts"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "format": "oxfmt --write",
    "lint": "npm-run-all -c typecheck eslint oxfmt",
    "eslint": "eslint --cache .",
    "oxfmt": "oxfmt --check",
    "lint:fix": "npm-run-all -c typecheck eslint:fix oxfmt:fix",
    "eslint:fix": "eslint --cache --fix .",
    "oxfmt:fix": "prettier -l -w .",
    "eslint:report": "eslint --cache --output-file eslint_report.json --format json .",
    "test": "vitest --run",
    "test:watch": "vitest --run --watch",
    "test-types": "vitest --typecheck --run --exclude '**/*.test.ts'",
    "test-all": "vitest --run --typecheck",
    "test-all:watch": "vitest --run --typecheck --watch",
    "typecheck": "tsgo",
    "typecheck:all": "tsgo --project tsconfig.all.json",
    "prepare": "npm-run-all -c prepare1 prepare2",
    "prepare1": "is-ci || husky",
    "prepare2": "patch-package"
  },
  "dependencies": {
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-markdown": "^6.5.0",
    "@massifrg/prosemirror-tables-sections": "^0.6.3",
    "@pixi/basis": "github:foundry-vtt-types/pixi-basis#main",
    "@pixi/graphics-smooth": "^1.1.1",
    "@pixi/particle-emitter": "github:foundry-vtt-types/pixi-particle-emitter#main",
    "@types/jquery": "^3.5.32",
    "@types/showdown": "~2.0.6",
    "@types/simple-peer": "~9.11.1",
    "@types/youtube": "~0.0.48",
    "codemirror": "^6.0.2",
    "handlebars": "^4.7.9",
    "handlebars-intl": "^1.1.2",
    "jquery": "^3.7.1",
    "mime-types": "^3.0.2",
    "peggy": "^5.1.0",
    "pixi-basis-ktx2": "^0.0.22",
    "pixi.js": "github:foundry-vtt-types/pixi.js#main",
    "prosemirror-collab": "^1.3.1",
    "prosemirror-commands": "^1.7.1",
    "prosemirror-dropcursor": "^1.8.2",
    "prosemirror-gapcursor": "^1.4.1",
    "prosemirror-history": "^1.5.0",
    "prosemirror-inputrules": "^1.5.1",
    "prosemirror-keymap": "^1.2.3",
    "prosemirror-model": "^1.25.4",
    "prosemirror-schema-list": "^1.5.1",
    "prosemirror-state": "^1.4.4",
    "prosemirror-transform": "^1.12.0",
    "prosemirror-view": "^1.41.8",
    "sanitize-html": "^2.17.3",
    "showdown": "^2.1.0",
    "simple-peer": "^9.11.1",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "spark-md5": "^3.0.2"
  },
  "devDependencies": {
    "@actions/core": "^3.0.0",
    "@actions/github": "^9.0.0",
    "@ark/attest": "^0.56.0",
    "@codemirror/lint": "^6.9.2",
    "@eslint/config-helpers": "^0.7.0",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "@types/debug": "^4.1.12",
    "@types/fvtt-types": "file:.",
    "@types/node": "^26.0.1",
    "@typescript-eslint/eslint-plugin": "^8.31.0",
    "@typescript-eslint/parser": "^8.31.0",
    "@typescript-eslint/scope-manager": "^8.31.0",
    "@typescript-eslint/utils": "^8.31.0",
    "@typescript/native-preview": "^7.0.0-dev.20251012.1",
    "@vitest/runner": "^4.0.15",
    "dotenv": "^17.2.3",
    "esbuild": "^0.28.0",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-import-resolver-typescript": "^4.3.2",
    "eslint-plugin-import-x": "^4.6.1",
    "eslint-plugin-jsdoc": "^63.0.0",
    "eslint-plugin-tsdoc": "^0.5.0",
    "get-port": "^7.1.0",
    "globals": "^17.4.0",
    "husky": "^9.1.4",
    "is-ci": "^4.1.0",
    "lint-staged": "^17.0.2",
    "normalize-url": "^9.0.0",
    "npm-run-all2": "^9.0.0",
    "oxfmt": "^0.60.0",
    "patch-package": "^8.0.1",
    "pathe": "^2.0.3",
    "playwright": "^1.60.0",
    "stacktrace-parser": "^0.1.11",
    "type-fest": "^5.0.1",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.31.0",
    "url-join": "^5.0.0",
    "vite": "^8.0.5",
    "vitest": "^4.0.15"
  },
  "peerDependencies": {
    "@typescript/native-preview": "*",
    "typescript": ">=5.4"
  },
  "peerDependenciesMeta": {
    "typescript": {
      "optional": true
    },
    "@typescript/native-preview": {
      "optional": true
    }
  },
  "overrides": {
    "@package-json/types": "^0.0.13",
    "expect-type": "^1.2.2"
  },
  "packageManager": "npm@10.8.1"
}
